{
  "expo": {
    "name": "Interview Quiz",
    "slug": "interview-quiz",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#f0f2f5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.interview.quiz",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "用于模拟面试录音与语音转文字"
      }
    },
    "android": {
      "package": "com.interview.quiz",
      "permissions": ["RECORD_AUDIO"]
    }
  }
}
